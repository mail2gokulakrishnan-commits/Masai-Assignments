import pandas as pd
import numpy as np

data = {
    'patient_id': [101, 102, 103, 104, 105, 106, 107, 108, 109, 110,
                   111, 112, 113, 114, 115, 101, 107, 118, 119, 120],

    'age': [25, 34, 35, 45, 29, 35, 38, 52, 27, 41,
            33, 35, 48, 26, 35, 25, 38, 31, 35, 44],

    'weight': [70, 65, 80, 75, 75, 75, 68, 90, 72, 85,
               78, 75, 82, 69, 75, 70, 68, 74, 75, 88],

    'blood_pressure': [120, 130, 128, 140, 125, 128, 135, 128, 118, 145,
                       128, 128, 138, 122, 128, 120, 135, 126, 128, 142],

    'medication': ['Aspirin', 'Metformin', 'Lisinopril', 'Aspirin', 'Aspirin',
                   'Metformin', 'Lisinopril', 'Aspirin', 'Aspirin', 'Metformin',
                   'Lisinopril', 'Aspirin', 'Aspirin', 'Metformin',
                   'Lisinopril', 'Aspirin', 'Lisinopril', 'Metformin',
                   'Aspirin', 'Aspirin'],

    'insurance_provider': ['Blue Cross', 'Aetna', 'Cigna', 'UnitedHealth', 'Unknown',
                           'Blue Cross', 'Aetna', 'Cigna', 'UnitedHealth', 'Blue Cross',
                           'Aetna', 'Unknown', 'UnitedHealth', 'Blue Cross', 'Aetna',
                           'Blue Cross', 'Aetna', 'Cigna', 'UnitedHealth', 'Unknown']
}

df = pd.DataFrame(data)


# Task 4: Handle Duplicates

print("All duplicate rows (full row comparison):")
print(df[df.duplicated(keep=False)])


print("\nDuplicate patient_id entries:")
print(df[df.duplicated(subset=['patient_id'], keep=False)])


print("\nShape before removing duplicates:", df.shape)


df_cleaned = df.drop_duplicates(subset=['patient_id'], keep='first')

print("Shape after removing duplicates:", df_cleaned.shape)


rows_removed = df.shape[0] - df_cleaned.shape[0]
print("Number of rows removed:", rows_removed)
